<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #003366;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uilogin.controller.SignUpController">
   <children>
      <AnchorPane layoutX="169.0" layoutY="46.0" prefHeight="307.0" prefWidth="299.0" style="-fx-background-color: white;">
         <children>
            <Label layoutX="21.0" layoutY="45.0" text="User name" />
            <Label layoutX="22.0" layoutY="82.0" text="Email" />
            <Label layoutX="21.0" layoutY="121.0" text="Password" />
            <Label layoutX="21.0" layoutY="162.0" text="Comfirm password" />
            <TextField layoutX="133.0" layoutY="41.0" fx:id="nameField" />
            <TextField layoutX="133.0" layoutY="78.0" fx:id="emailField" />
            <Button layoutX="124.0" layoutY="206.0" mnemonicParsing="false" style="-fx-background-color: #003366;" text="Sign Up" textFill="WHITE" fx:id="signUpButton" onAction="#onSignUp" />
            <PasswordField layoutX="133.0" layoutY="117.0" fx:id="passwordField" />
            <PasswordField layoutX="133.0" layoutY="158.0" fx:id="confirmPasswordField" />
            <Label layoutX="78.0" layoutY="246.0" text="Have an acount?" />
            <Button layoutX="176.0" layoutY="242.0" mnemonicParsing="false" text="Log In" fx:id="loginButton" onAction="#onLogin" />
         </children></AnchorPane>
   </children>
</AnchorPane>

